{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["electron/main/*"],
      "@shared/*": ["shared/*"]
    },
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts", "electron.vite.config.ts"]
}
